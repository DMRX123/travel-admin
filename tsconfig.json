{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "components/Table.js",
    "pages/driver/dashboard.js",
    "pages/route/[from]-to-[to].js",
    "components/PaymentModal.js",
    "components/Vehicle3D.js",
    "components/VehicleTracker.js",
    "context/LanguageContext.js",
    "lib/firebase.js",
    "components/LanguageSwitcher.js",
    "components/AnimatedBackground.js",
    "context/NotificationContext.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
